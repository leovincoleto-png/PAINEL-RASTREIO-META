# Subdomínio da sua Kommo.
# Exemplo: se sua conta é https://minhaclinica.kommo.com, use:
KOMMO_SUBDOMAIN=minhaclinica

# Token de longa duração da integração privada.
KOMMO_TOKEN=cole_o_token_aqui

# Porta usada pelo Render. Pode deixar assim.
PORT=3000

# Preferencial: use IDs reais dos funis.
# Se não souber os IDs, o sistema tenta localizar pelo nome.
# RECEPTION_PIPELINE_ID=
# SURGERY_PIPELINE_ID=

# Nomes dos funis caso não use IDs.
RECEPTION_PIPELINE_NAME=RECEPCAO
SURGERY_PIPELINE_NAME=EXECUSAO DE CIRURGIA

# Opcional: ID do status Fechado ganho.
# Em muitas contas Kommo/amoCRM, o ganho é 142.
# Se sua conta usar outro ID, configure aqui.
# WON_STATUS_ID=142
WON_STATUS_NAME=Fechado ganho
